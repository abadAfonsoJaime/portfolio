# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# EmailJS Configuration
# Copy this file to .env.local and replace with your actual EmailJS credentials
# Get these values from https://emailjs.com after setting up your account

# Service ID - from EmailJS Email Services section
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here

# Template ID - from EmailJS Email Templates section
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here

# Public Key - from EmailJS Account > API Keys section
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# Contentful Configuration (optional)
NEXT_PUBLIC_CONTENTFUL_SPACE_ID=your-space-id
NEXT_PUBLIC_CONTENTFUL_ACCESS_TOKEN=your-access-token
